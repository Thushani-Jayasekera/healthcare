{
  "openapi": "3.0.3",
  "info": {
    "title": "Healthcare Specialist Booking API",
    "version": "1.0.0",
    "description": "RESTful API for booking specialist treatments across doctors and hospitals. Supports patient management, treatment discovery, provider lookup, availability scheduling, pricing estimates, bookings, and notifications."
  },
  "servers": [
    {
      "url": "https://api.healthcare.example.com/v1",
      "description": "Production"
    },
    {
      "url": "https://sandbox.healthcare.example.com/v1",
      "description": "Sandbox"
    }
  ],
  "tags": [
    { "name": "Patients",      "description": "Patient profile management" },
    { "name": "Treatments",    "description": "Treatment search and details" },
    { "name": "Providers",     "description": "Doctor and hospital lookup" },
    { "name": "Availability",  "description": "Provider slot availability" },
    { "name": "Bookings",      "description": "Appointment lifecycle" },
    { "name": "Pricing",       "description": "Treatment cost estimates" },
    { "name": "Notifications", "description": "Confirmation delivery" }
  ],
  "paths": {

    "/patients": {
      "post": {
        "tags": ["Patients"],
        "operationId": "createPatient",
        "summary": "Create a new patient record",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreatePatientRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Patient created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Patient" }
              }
            }
          },
          "409": {
            "description": "Patient already exists (matched by email)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConflictError" }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },

    "/patients/{patientId}": {
      "get": {
        "tags": ["Patients"],
        "operationId": "getPatient",
        "summary": "Get patient profile by ID",
        "parameters": [
          {
            "name": "patientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Patient profile",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Patient" }
              }
            }
          },
          "404": {
            "description": "Patient not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NotFoundError" }
              }
            }
          }
        }
      }
    },

    "/treatments/search": {
      "get": {
        "tags": ["Treatments"],
        "operationId": "searchTreatments",
        "summary": "Search treatments by condition or specialty",
        "parameters": [
          {
            "name": "condition",
            "in": "query",
            "description": "Patient condition or symptom keywords",
            "schema": { "type": "string" },
            "example": "lower back pain"
          },
          {
            "name": "specialty",
            "in": "query",
            "description": "Medical specialty",
            "schema": { "type": "string" },
            "example": "Orthopedics"
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 10, "maximum": 50 }
          }
        ],
        "responses": {
          "200": {
            "description": "List of matching treatments",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TreatmentSearchResponse" }
              }
            }
          },
          "400": {
            "description": "Missing required query parameters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BadRequestError" }
              }
            }
          }
        }
      }
    },

    "/treatments/{treatmentId}": {
      "get": {
        "tags": ["Treatments"],
        "operationId": "getTreatment",
        "summary": "Get full details for a specific treatment",
        "parameters": [
          {
            "name": "treatmentId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Treatment details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Treatment" }
              }
            }
          },
          "404": {
            "description": "Treatment not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NotFoundError" }
              }
            }
          }
        }
      }
    },

    "/providers": {
      "get": {
        "tags": ["Providers"],
        "operationId": "listProviders",
        "summary": "List doctors and hospitals matching specialty and location",
        "parameters": [
          {
            "name": "specialty",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "example": "Orthopedics"
          },
          {
            "name": "location",
            "in": "query",
            "description": "City or suburb name",
            "schema": { "type": "string" },
            "example": "Sydney"
          },
          {
            "name": "radius_km",
            "in": "query",
            "description": "Search radius in kilometres",
            "schema": { "type": "number", "default": 25 }
          },
          {
            "name": "accepting_new_patients",
            "in": "query",
            "schema": { "type": "boolean", "default": true }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 10, "maximum": 50 }
          }
        ],
        "responses": {
          "200": {
            "description": "List of matching providers",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ProviderListResponse" }
              }
            }
          },
          "400": {
            "description": "Invalid parameters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BadRequestError" }
              }
            }
          }
        }
      }
    },

    "/providers/{providerId}": {
      "get": {
        "tags": ["Providers"],
        "operationId": "getProvider",
        "summary": "Get full details for a specific provider",
        "parameters": [
          {
            "name": "providerId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Provider details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Provider" }
              }
            }
          },
          "404": {
            "description": "Provider not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NotFoundError" }
              }
            }
          }
        }
      }
    },

    "/providers/{providerId}/availability": {
      "get": {
        "tags": ["Availability"],
        "operationId": "getProviderAvailability",
        "summary": "Get available appointment slots for a provider",
        "parameters": [
          {
            "name": "providerId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "date_from",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "date" },
            "example": "2026-05-01"
          },
          {
            "name": "date_to",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "date" },
            "example": "2026-05-14"
          },
          {
            "name": "treatment_id",
            "in": "query",
            "description": "Filter slots suitable for the treatment duration",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Available time slots",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AvailabilityResponse" }
              }
            }
          },
          "404": {
            "description": "Provider not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NotFoundError" }
              }
            }
          }
        }
      }
    },

    "/pricing/estimate": {
      "get": {
        "tags": ["Pricing"],
        "operationId": "getPricingEstimate",
        "summary": "Get cost estimate for a treatment at a specific provider",
        "parameters": [
          {
            "name": "treatment_id",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "provider_id",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "patient_id",
            "in": "query",
            "description": "Used to apply insurance / fund discounts if available",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Pricing estimate",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PricingEstimate" }
              }
            }
          },
          "404": {
            "description": "Treatment or provider not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NotFoundError" }
              }
            }
          }
        }
      }
    },

    "/bookings": {
      "post": {
        "tags": ["Bookings"],
        "operationId": "createBooking",
        "summary": "Create a new appointment booking",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateBookingRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Booking confirmed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Booking" }
              }
            }
          },
          "409": {
            "description": "Slot no longer available",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConflictError" }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },

    "/bookings/{bookingId}": {
      "get": {
        "tags": ["Bookings"],
        "operationId": "getBooking",
        "summary": "Get booking details by ID",
        "parameters": [
          {
            "name": "bookingId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Booking details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Booking" }
              }
            }
          },
          "404": {
            "description": "Booking not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NotFoundError" }
              }
            }
          }
        }
      }
    },

    "/bookings/{bookingId}/cancel": {
      "post": {
        "tags": ["Bookings"],
        "operationId": "cancelBooking",
        "summary": "Cancel an existing booking",
        "parameters": [
          {
            "name": "bookingId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CancelBookingRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Booking cancelled",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Booking" }
              }
            }
          },
          "404": {
            "description": "Booking not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NotFoundError" }
              }
            }
          },
          "422": {
            "description": "Booking cannot be cancelled (e.g. within 24 hr window)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },

    "/bookings/{bookingId}/reschedule": {
      "post": {
        "tags": ["Bookings"],
        "operationId": "rescheduleBooking",
        "summary": "Reschedule an existing booking to a new slot",
        "parameters": [
          {
            "name": "bookingId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RescheduleBookingRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Booking rescheduled",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Booking" }
              }
            }
          },
          "409": {
            "description": "New slot no longer available",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConflictError" }
              }
            }
          },
          "404": {
            "description": "Booking not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NotFoundError" }
              }
            }
          }
        }
      }
    },

    "/notifications/confirmation": {
      "post": {
        "tags": ["Notifications"],
        "operationId": "sendBookingConfirmation",
        "summary": "Send booking confirmation via email and/or SMS",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SendConfirmationRequest" }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Confirmation queued for delivery",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NotificationReceipt" }
              }
            }
          },
          "422": {
            "description": "Missing or invalid contact details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    }

  },

  "components": {
    "schemas": {

      "CreatePatientRequest": {
        "type": "object",
        "required": ["first_name", "last_name", "date_of_birth", "email", "phone"],
        "properties": {
          "first_name":    { "type": "string", "example": "Jane" },
          "last_name":     { "type": "string", "example": "Smith" },
          "date_of_birth": { "type": "string", "format": "date", "example": "1985-03-22" },
          "email":         { "type": "string", "format": "email", "example": "jane.smith@email.com" },
          "phone":         { "type": "string", "example": "+61412345678" },
          "gender":        { "type": "string", "enum": ["male","female","non_binary","prefer_not_to_say"] },
          "address": { "$ref": "#/components/schemas/Address" },
          "insurance": { "$ref": "#/components/schemas/InsuranceInfo" }
        }
      },

      "Patient": {
        "type": "object",
        "properties": {
          "patient_id":    { "type": "string", "format": "uuid", "example": "a1b2c3d4-0000-0000-0000-000000000001" },
          "first_name":    { "type": "string" },
          "last_name":     { "type": "string" },
          "date_of_birth": { "type": "string", "format": "date" },
          "email":         { "type": "string", "format": "email" },
          "phone":         { "type": "string" },
          "gender":        { "type": "string" },
          "address":       { "$ref": "#/components/schemas/Address" },
          "insurance":     { "$ref": "#/components/schemas/InsuranceInfo" },
          "created_at":    { "type": "string", "format": "date-time" }
        }
      },

      "Address": {
        "type": "object",
        "properties": {
          "street":   { "type": "string", "example": "42 Harbour St" },
          "city":     { "type": "string", "example": "Sydney" },
          "state":    { "type": "string", "example": "NSW" },
          "postcode": { "type": "string", "example": "2000" },
          "country":  { "type": "string", "example": "AU" }
        }
      },

      "InsuranceInfo": {
        "type": "object",
        "properties": {
          "fund_name":    { "type": "string", "example": "Medibank" },
          "member_id":    { "type": "string", "example": "MBK-9876543" },
          "policy_level": { "type": "string", "enum": ["basic","bronze","silver","gold","platinum"] }
        }
      },

      "TreatmentSearchResponse": {
        "type": "object",
        "properties": {
          "total":  { "type": "integer", "example": 8 },
          "page":   { "type": "integer", "example": 1 },
          "limit":  { "type": "integer", "example": 10 },
          "items":  {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TreatmentSummary" }
          }
        }
      },

      "TreatmentSummary": {
        "type": "object",
        "properties": {
          "treatment_id": { "type": "string", "format": "uuid", "example": "t1000000-0000-0000-0000-000000000001" },
          "name":         { "type": "string", "example": "Lumbar Spinal Decompression" },
          "specialty":    { "type": "string", "example": "Orthopedics" },
          "description":  { "type": "string" },
          "duration_min": { "type": "integer", "description": "Typical appointment duration in minutes", "example": 60 }
        }
      },

      "Treatment": {
        "allOf": [
          { "$ref": "#/components/schemas/TreatmentSummary" },
          {
            "type": "object",
            "properties": {
              "procedure_codes": {
                "type": "array",
                "items": { "type": "string" },
                "example": ["MBS-51011","MBS-51012"]
              },
              "prerequisites": {
                "type": "array",
                "items": { "type": "string" },
                "example": ["GP referral required", "MRI scan within 12 months"]
              },
              "typical_recovery_days": { "type": "integer", "example": 14 },
              "related_specialties": {
                "type": "array",
                "items": { "type": "string" },
                "example": ["Neurosurgery","Physiotherapy"]
              },
              "updated_at": { "type": "string", "format": "date-time" }
            }
          }
        ]
      },

      "ProviderListResponse": {
        "type": "object",
        "properties": {
          "total": { "type": "integer", "example": 5 },
          "page":  { "type": "integer", "example": 1 },
          "limit": { "type": "integer", "example": 10 },
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ProviderSummary" }
          }
        }
      },

      "ProviderSummary": {
        "type": "object",
        "properties": {
          "provider_id":            { "type": "string", "format": "uuid", "example": "p2000000-0000-0000-0000-000000000002" },
          "name":                   { "type": "string", "example": "Dr. Marcus Chen" },
          "type":                   { "type": "string", "enum": ["doctor","hospital","clinic"] },
          "specialty":              { "type": "string", "example": "Orthopedics" },
          "location":               { "$ref": "#/components/schemas/Address" },
          "rating":                 { "type": "number", "format": "float", "example": 4.7 },
          "accepting_new_patients": { "type": "boolean", "example": true },
          "distance_km":            { "type": "number", "example": 3.2 }
        }
      },

      "Provider": {
        "allOf": [
          { "$ref": "#/components/schemas/ProviderSummary" },
          {
            "type": "object",
            "properties": {
              "qualifications":   { "type": "array", "items": { "type": "string" }, "example": ["MBBS","FRACS (Ortho)"] },
              "languages":        { "type": "array", "items": { "type": "string" }, "example": ["English","Mandarin"] },
              "phone":            { "type": "string", "example": "+61292345678" },
              "email":            { "type": "string", "format": "email" },
              "website":          { "type": "string", "format": "uri" },
              "accepted_funds":   { "type": "array", "items": { "type": "string" }, "example": ["Medibank","BUPA","HCF"] },
              "services":         { "type": "array", "items": { "type": "string" } },
              "consultation_fee": { "type": "number", "example": 280.00 }
            }
          }
        ]
      },

      "AvailabilityResponse": {
        "type": "object",
        "properties": {
          "provider_id": { "type": "string", "format": "uuid" },
          "date_from":   { "type": "string", "format": "date" },
          "date_to":     { "type": "string", "format": "date" },
          "slots": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TimeSlot" }
          },
          "next_available_date": {
            "type": "string",
            "format": "date",
            "description": "Earliest date with available slots beyond the requested range. Null if slots found in range.",
            "nullable": true
          }
        }
      },

      "TimeSlot": {
        "type": "object",
        "properties": {
          "slot_id":    { "type": "string", "format": "uuid", "example": "s3000000-0000-0000-0000-000000000003" },
          "start_time": { "type": "string", "format": "date-time", "example": "2026-05-05T09:00:00+10:00" },
          "end_time":   { "type": "string", "format": "date-time", "example": "2026-05-05T10:00:00+10:00" },
          "status":     { "type": "string", "enum": ["available","held","booked"] }
        }
      },

      "PricingEstimate": {
        "type": "object",
        "properties": {
          "treatment_id":       { "type": "string", "format": "uuid" },
          "provider_id":        { "type": "string", "format": "uuid" },
          "currency":           { "type": "string", "example": "AUD" },
          "gross_fee":          { "type": "number", "example": 1200.00 },
          "medicare_rebate":    { "type": "number", "example": 420.00, "description": "Estimated public rebate. Zero if not applicable." },
          "insurance_benefit":  { "type": "number", "example": 350.00, "description": "Estimated private health fund benefit. Zero if patient has no insurance or fund not accepted." },
          "estimated_gap":      { "type": "number", "example": 430.00 },
          "out_of_pocket":      { "type": "number", "example": 430.00 },
          "disclaimer":         { "type": "string", "example": "This is an estimate only. Final costs depend on clinical decisions made during the procedure." },
          "valid_until":        { "type": "string", "format": "date-time" }
        }
      },

      "CreateBookingRequest": {
        "type": "object",
        "required": ["patient_id", "provider_id", "treatment_id", "slot_id"],
        "properties": {
          "patient_id":   { "type": "string", "format": "uuid" },
          "provider_id":  { "type": "string", "format": "uuid" },
          "treatment_id": { "type": "string", "format": "uuid" },
          "slot_id":      { "type": "string", "format": "uuid" },
          "notes":        { "type": "string", "example": "Patient has latex allergy. GP referral attached." },
          "referral_id":  { "type": "string", "description": "GP referral reference number if applicable" }
        }
      },

      "Booking": {
        "type": "object",
        "properties": {
          "booking_id":      { "type": "string", "format": "uuid", "example": "b4000000-0000-0000-0000-000000000004" },
          "patient_id":      { "type": "string", "format": "uuid" },
          "provider_id":     { "type": "string", "format": "uuid" },
          "treatment_id":    { "type": "string", "format": "uuid" },
          "slot_id":         { "type": "string", "format": "uuid" },
          "start_time":      { "type": "string", "format": "date-time" },
          "end_time":        { "type": "string", "format": "date-time" },
          "status":          { "type": "string", "enum": ["confirmed","pending","cancelled","completed","rescheduled"] },
          "notes":           { "type": "string" },
          "referral_id":     { "type": "string" },
          "confirmation_code": { "type": "string", "example": "HC-2026-88421" },
          "created_at":      { "type": "string", "format": "date-time" },
          "updated_at":      { "type": "string", "format": "date-time" }
        }
      },

      "CancelBookingRequest": {
        "type": "object",
        "required": ["reason"],
        "properties": {
          "reason": { "type": "string", "example": "Patient unable to attend" }
        }
      },

      "RescheduleBookingRequest": {
        "type": "object",
        "required": ["new_slot_id"],
        "properties": {
          "new_slot_id": { "type": "string", "format": "uuid" },
          "reason":      { "type": "string" }
        }
      },

      "SendConfirmationRequest": {
        "type": "object",
        "required": ["booking_id", "channels"],
        "properties": {
          "booking_id": { "type": "string", "format": "uuid" },
          "channels":   {
            "type": "array",
            "items": { "type": "string", "enum": ["email","sms"] },
            "example": ["email","sms"]
          },
          "override_email": { "type": "string", "format": "email", "description": "Override the patient's registered email for this notification" },
          "override_phone": { "type": "string", "description": "Override the patient's registered phone for this notification" }
        }
      },

      "NotificationReceipt": {
        "type": "object",
        "properties": {
          "notification_id": { "type": "string", "format": "uuid" },
          "booking_id":      { "type": "string", "format": "uuid" },
          "channels_sent":   { "type": "array", "items": { "type": "string" } },
          "status":          { "type": "string", "enum": ["queued","delivered","failed"] },
          "queued_at":       { "type": "string", "format": "date-time" }
        }
      },

      "BadRequestError": {
        "type": "object",
        "properties": {
          "error":   { "type": "string", "example": "bad_request" },
          "message": { "type": "string", "example": "At least one of 'condition' or 'specialty' is required" }
        }
      },

      "NotFoundError": {
        "type": "object",
        "properties": {
          "error":   { "type": "string", "example": "not_found" },
          "message": { "type": "string", "example": "The requested resource was not found" }
        }
      },

      "ConflictError": {
        "type": "object",
        "properties": {
          "error":   { "type": "string", "example": "conflict" },
          "message": { "type": "string", "example": "This slot is no longer available" }
        }
      },

      "ValidationError": {
        "type": "object",
        "properties": {
          "error":   { "type": "string", "example": "validation_error" },
          "message": { "type": "string" },
          "fields":  {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field":   { "type": "string" },
                "message": { "type": "string" }
              }
            }
          }
        }
      }

    }
  }
}
